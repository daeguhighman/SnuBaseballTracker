{
  "compilerOptions": {
    "module": "commonjs",
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "target": "ES2021",
    "sourceMap": true,
    "outDir": "./dist",
    "baseUrl": "./",

    "paths": {
      "@/*": ["src/*"],
      "@teams/*": ["src/teams/*"],
      "@players/*": ["src/players/*"],
      "@users/*": ["src/users/*"],
      "@records/*": ["src/records/*"],
      "@tournaments/*": ["src/tournaments/*"],
      "@games/*": ["src/games/*"],
      "@umpires/*": ["src/umpires/*"],
      "@mail/*": ["src/mail/*"],
      "@auth/*": ["src/auth/*"],
      "@common/*": ["src/common/*"],
      "@config/*": ["src/config/*"],
      "@admin/*": ["src/admin/*"],
      "@profile/*": ["src/profile/*"],
      "@sessions/*": ["src/sessions/*"],
      "@plays/*": ["src/plays/*"],
      "@seed/*": ["src/seed/*"],
      "@test/*": ["src/test/*"]
    },

    "incremental": true,
    "skipLibCheck": true,
    "strictNullChecks": false,
    "noImplicitAny": false,
    "strictBindCallApply": false,
    "forceConsistentCasingInFileNames": false,
    "noFallthroughCasesInSwitch": false,
    "inlineSources": true,
    
    // Enhanced IntelliSense and AI suggestions
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "moduleResolution": "node",
    "lib": ["ES2021"],
    "types": ["node", "jest"],

    // Set `sourceRoot` to  "/" to strip the build path prefix
    // from generated source code references.
    // This improves issue grouping in Sentry.
    "sourceRoot": "/"
  },
  
  "include": [
    "src/**/*",
    "test/**/*"
  ],
  
  "exclude": [
    "node_modules",
    "dist",
    "**/*.spec.ts"
  ]
}
